<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xsi:type="MailApp">
<Id>9c8b7412-1234-4567-a89b-bcdef1234567</Id>
<Version>2.0.4.0</Version>
<ProviderName>Hedelius</ProviderName>
<DefaultLocale>de-DE</DefaultLocale>
<DisplayName DefaultValue="Hedelius-Outlook-Add-In"/>
<Description DefaultValue="Dynamics 365 Ticket-Integration für Hedelius Maschinenfabrik"/>
<Hosts>
  <Host Name="Mailbox"/>
</Hosts>
<Requirements>
  <Sets>
    <Set Name="Mailbox" MinVersion="1.1"/>
  </Sets>
</Requirements>
<!-- Fallback für ältere Clients -->
<FormSettings>
  <Form xsi:type="ItemRead">
    <DesktopSettings>
      <SourceLocation DefaultValue="https://henne49808.github.io/Service-outlook-addin/taskpane.html"/>
      <RequestedHeight>450</RequestedHeight>
    </DesktopSettings>
  </Form>
</FormSettings>
<Permissions>ReadWriteItem</Permissions>
<Rule xsi:type="RuleCollection" Mode="Or">
  <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
</Rule>

<!-- V1_0: Fallback für Exchange 2013/2016 ohne V1_1-Unterstützung -->
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
  <Requirements>
    <bt:Sets DefaultMinVersion="1.1">
      <bt:Set Name="Mailbox"/>
    </bt:Sets>
  </Requirements>
  <Hosts>
    <Host xsi:type="MailHost">
      <DesktopFormFactor>
        <FunctionFile resid="paneUrl"/>
        <ExtensionPoint xsi:type="MessageReadCommandSurface">
          <OfficeTab id="TabDefault">
            <Group id="Hedelius.Group">
              <Label resid="groupLabel"/>
              <Control xsi:type="Button" id="Hedelius.OpenPane">
                <Label resid="paneButtonLabel"/>
                <Supertip>
                  <Title resid="paneButtonLabel"/>
                  <Description resid="paneButtonTooltip"/>
                </Supertip>
                <Icon>
                  <bt:Image size="16" resid="icon16"/>
                  <bt:Image size="32" resid="icon32"/>
                  <bt:Image size="80" resid="icon80"/>
                </Icon>
                <Action xsi:type="ShowTaskpane">
                  <SourceLocation resid="paneUrl"/>
                </Action>
              </Control>
            </Group>
          </OfficeTab>
        </ExtensionPoint>
      </DesktopFormFactor>
    </Host>
  </Hosts>
  <Resources>
    <bt:Images>
      <bt:Image id="icon16" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon16.png"/>
      <bt:Image id="icon32" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon32.png"/>
      <bt:Image id="icon80" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon80.png"/>
    </bt:Images>
    <bt:Urls>
      <bt:Url id="paneUrl" DefaultValue="https://henne49808.github.io/Service-outlook-addin/taskpane.html"/>
    </bt:Urls>
    <bt:ShortStrings>
      <bt:String id="groupLabel" DefaultValue="Hedelius"/>
      <bt:String id="paneButtonLabel" DefaultValue="Service"/>
    </bt:ShortStrings>
    <bt:LongStrings>
      <bt:String id="paneButtonTooltip" DefaultValue="Dynamics 365 Ticket-Informationen zur aktuellen E-Mail anzeigen"/>
    </bt:LongStrings>
  </Resources>

  <!-- V1_1: Für Exchange 2019 / Microsoft 365 – mit Pinning, NoItemContext und SharedFolders -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>
    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <!-- Freigegebene Postfächer aktivieren -->
          <SupportsSharedFolders>true</SupportsSharedFolders>
          <FunctionFile resid="paneUrl"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="Hedelius.Group.v11">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="Hedelius.OpenPane.v11">
                  <Label resid="paneButtonLabel"/>
                  <Supertip>
                    <Title resid="paneButtonLabel"/>
                    <Description resid="paneButtonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="paneUrl"/>
                    <SupportsPinning>true</SupportsPinning>
                    <SupportsNoItemContext>true</SupportsNoItemContext>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon16.png"/>
        <bt:Image id="icon32" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon32.png"/>
        <bt:Image id="icon80" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="paneUrl" DefaultValue="https://henne49808.github.io/Service-outlook-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="Hedelius"/>
        <bt:String id="paneButtonLabel" DefaultValue="Service"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButtonTooltip" DefaultValue="Dynamics 365 Ticket-Informationen zur aktuellen E-Mail anzeigen"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>

</VersionOverrides>
</OfficeApp>
