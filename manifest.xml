<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appsweb/manifest/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>9c8b7412-1234-4567-a89b-bcdef1234567</Id>
  <Version>2.0.0.0</Version>
  <ProviderName>Hedelius Maschinenfabrik</ProviderName>
  <DefaultLocale>de-DE</DefaultLocale>
  <DisplayName DefaultValue="Hedelius-Outlook-Add-In"/>
  <Description DefaultValue="Dynamics 365 Ticket-Integration für Hedelius Maschinenfabrik"/>

  <!-- Fallback für sehr alte Outlook-Versionen -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://henne49808.github.io/Service-outlook-addin/taskpane.html"/>
        <RequestedHeight>500</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <!-- ✅ MODERN: VersionOverrides aktiviert den rechten Task Pane -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.1">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <!-- Funktionsseite (wird intern benötigt) -->
          <FunctionFile resid="functionFile"/>

          <!-- ✅ MessageReadCommandSurface = Add-In erscheint beim Lesen einer E-Mail im Task Pane rechts -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="groupLabel"/>

                <!-- Button in der Outlook-Ribbon-Leiste -->
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="paneButtonLabel"/>
                  <Supertip>
                    <Title resid="paneButtonLabel"/>
                    <Description resid="paneButtonTooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <!-- ✅ ShowTaskpane öffnet das Add-In als angedockte Seitenleiste rechts -->
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="paneUrl"/>
                    <!-- ✅ SupportsPinning erlaubt das Andocken (wie Dynamics 365) -->
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon16.png"/>
        <bt:Image id="icon32" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon32.png"/>
        <bt:Image id="icon80" DefaultValue="https://henne49808.github.io/Service-outlook-addin/icon80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://henne49808.github.io/Service-outlook-addin/taskpane.html"/>
        <bt:Url id="paneUrl"      DefaultValue="https://henne49808.github.io/Service-outlook-addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel"        DefaultValue="Hedelius"/>
        <bt:String id="paneButtonLabel"   DefaultValue="Hedelius Add-In"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButtonTooltip" DefaultValue="Dynamics 365 Ticket-Informationen zur aktuellen E-Mail anzeigen"/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
